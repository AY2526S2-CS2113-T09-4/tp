@startuml
actor User
participant ":Parser" as Parser
participant ":TransactionsList" as List
participant ":Storage" as Store

alt Single Delete
    User -> Parser : "delete 5"
    Parser -> List : deleteTransaction(5)
else Bulk Delete
    User -> Parser : "delete -match 'Lunch'"
    Parser -> List : filterTransactions(...)
    loop for each match
        List -> List : remove(transaction)
    end
end

List -> Store : save(transactions)
List -> List : refreshBalanceSheetCsv()
List --> User : "Successfully deleted..."
@enduml
