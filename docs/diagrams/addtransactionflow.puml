@startuml
actor User
participant ":Parser" as Parser
participant ":UiAssistFactory" as UI
participant ":PresetHandler" as Preset
participant ":Transaction" as Trans
participant ":TransactionsList" as List
participant ":Storage" as Store

User -> Parser : "add -date ... -preset ..."
alt UI Assist Enabled
    Parser -> UI : getInteractiveArguments("add")
    UI --> Parser : generated command string
end

Parser -> Preset : generatePostings(presetData)
Preset --> Parser : List<Posting>

Parser -> Trans ** : new Transaction(date, desc, postings, currency)
Parser -> List : addTransaction(t)
List -> Trans : isBalanced()
Trans --> List : true
List -> Store : save(transactions)
List -> List : refreshBalanceSheetCsv()
List --> User : "Transaction added successfully"
@enduml
