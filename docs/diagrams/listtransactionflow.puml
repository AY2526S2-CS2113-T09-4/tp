@startuml
actor User
participant ":Parser" as Parser
participant ":TransactionsList" as List
participant ":CurrencyConverter" as Converter

User -> Parser : "list -acc Expenses -to USD"
Parser -> List : filterTransactionsByDate(...)
Parser -> List : filterTransactionsByRegex(...)
Parser -> List : filterTransactionsByAccount("Expenses")
List --> Parser : List<Transaction> (filtered)

Parser -> List : renderTransactions(results)
loop for each transaction
    List -> Converter : convert(amount, from, "USD")
    Converter --> List : convertedAmount
    List -> User : Print ID, Date, Postings (Display: USD)
end

Parser -> Parser : setPendingState(target: "USD", fromList: true)
Parser --> User : "Type 'confirm all' to store conversions"
@enduml
